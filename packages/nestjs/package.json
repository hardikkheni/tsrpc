{
  "name": "@jsontpc/nestjs",
  "version": "0.1.0",
  "description": "NestJS module/decorator adapter for @jsontpc/core",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jsontpc/core": "workspace:*"
  },
  "devDependencies": {
    "@jsontpc/http": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "supertest": "^7.0.0",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "reflect-metadata": ">=0.2",
    "rxjs": ">=7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hardikkheni/jsontpc.git",
    "directory": "packages/nestjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
